{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "brand": "Toby Music",
    "slogan": "אומנות ואמינות – זו יצירה",
    "version": "2.0",
    "description": "Official design tokens for all Toby Music digital touchpoints. Use in Figma (Tokens Studio), Lovable, Fillout, Framer, Webflow, or any CSS/JS context.",
    "author": "Toby Weinberg"
  },
  "color": {
    "fire": {
      "bright": { "$value": "hsl(32, 92%, 54%)", "$hex": "#F3921E", "$description": "Fire bright orange – main brand energy" },
      "core":   { "$value": "hsl(20, 88%, 44%)", "$hex": "#CF4112", "$description": "Ember red – fire midpoint" },
      "deep":   { "$value": "hsl(7,  82%, 30%)", "$hex": "#8E1B08", "$description": "Deep dark red – fire shadow" }
    },
    "gold": {
      "main":  { "$value": "hsl(42, 80%, 58%)", "$hex": "#D9A22A", "$description": "Warm gold – quality marker" },
      "dark":  { "$value": "hsl(38, 65%, 44%)", "$hex": "#AD7C1F", "$description": "Deep gold" },
      "light": { "$value": "hsl(46, 90%, 72%)", "$hex": "#ECC84E", "$description": "Light gold / champagne" }
    },
    "wine": {
      "deep":  { "$value": "hsl(346, 60%, 24%)", "$hex": "#63101E", "$description": "Deep burgundy wine – trust" },
      "main":  { "$value": "hsl(349, 52%, 42%)", "$hex": "#9E2E3F", "$description": "Medium wine – accent" },
      "light": { "$value": "hsl(352, 46%, 52%)", "$hex": "#A8485A", "$description": "Light wine / rose" }
    },
    "neutral": {
      "950": { "$value": "hsl(18, 20%, 7%)",  "$hex": "#150E09", "$description": "Near-black warm – dark mode bg" },
      "900": { "$value": "hsl(18, 16%, 11%)", "$hex": "#1E1510", "$description": "Dark surface" },
      "800": { "$value": "hsl(20, 14%, 15%)", "$hex": "#272018", "$description": "Elevated surface" },
      "700": { "$value": "hsl(22, 16%, 22%)", "$hex": "#3A2D24", "$description": "Border dark" },
      "500": { "$value": "hsl(24, 10%, 50%)", "$hex": "#8A7A72", "$description": "Muted" },
      "200": { "$value": "hsl(28, 20%, 80%)", "$hex": "#CEBFB0", "$description": "Border light" },
      "100": { "$value": "hsl(30, 22%, 94%)", "$hex": "#EDE4D9", "$description": "Light surface" },
      "50":  { "$value": "hsl(34, 28%, 97%)", "$hex": "#F8F4EE", "$description": "Near-white warm – light mode bg" }
    }
  },
  "gradient": {
    "fire":             { "$value": "linear-gradient(135deg, hsl(32,92%,54%), hsl(20,88%,44%), hsl(7,82%,30%))" },
    "fire-horizontal": { "$value": "linear-gradient(90deg,  hsl(32,92%,54%), hsl(7,82%,30%))" },
    "fire-vertical":   { "$value": "linear-gradient(180deg, hsl(32,92%,54%), hsl(7,82%,30%))" },
    "gold":            { "$value": "linear-gradient(135deg, hsl(46,90%,72%), hsl(42,80%,58%), hsl(38,65%,44%))" },
    "brand":           { "$value": "linear-gradient(135deg, hsl(32,92%,54%), hsl(346,60%,24%))" }
  },
  "typography": {
    "fontFamily": {
      "display-hebrew": { "$value": "'Frank Ruhl Libre', 'Playfair Display', Georgia, serif" },
      "display-latin":  { "$value": "'Cormorant Garamond', 'Frank Ruhl Libre', Georgia, serif" },
      "body":           { "$value": "'Assistant', system-ui, -apple-system, sans-serif" }
    },
    "scale": {
      "xs":   { "$value": "0.75rem",  "$px": "12" },
      "sm":   { "$value": "0.875rem", "$px": "14" },
      "base": { "$value": "1rem",     "$px": "16" },
      "lg":   { "$value": "1.125rem", "$px": "18" },
      "xl":   { "$value": "1.25rem",  "$px": "20" },
      "2xl":  { "$value": "1.5rem",   "$px": "24" },
      "3xl":  { "$value": "1.875rem", "$px": "30" },
      "4xl":  { "$value": "2.25rem",  "$px": "36" },
      "5xl":  { "$value": "3rem",     "$px": "48" },
      "6xl":  { "$value": "3.75rem",  "$px": "60" }
    }
  },
  "shadow": {
    "sm":          { "$value": "0 2px 10px  rgba(21,14,9,0.10)" },
    "md":          { "$value": "0 8px 36px  rgba(21,14,9,0.15)" },
    "lg":          { "$value": "0 16px 48px rgba(21,14,9,0.22)" },
    "glow-fire":   { "$value": "0 0 18px rgba(243,146,30,0.28), 0 0 52px rgba(207,65,18,0.16)" },
    "glow-fire-i": { "$value": "0 0 28px rgba(243,146,30,0.52), 0 0 80px rgba(207,65,18,0.30)" },
    "glow-gold":   { "$value": "0 0 18px rgba(217,155,30,0.34), 0 0 50px rgba(173,116,24,0.18)" },
    "glow-wine":   { "$value": "0 0 18px rgba(158,46,63,0.34),  0 0 50px rgba(99,16,30,0.22)"  }
  },
  "animation": {
    "duration": {
      "fast":     { "$value": "0.18s" },
      "normal":   { "$value": "0.32s" },
      "slow":     { "$value": "0.55s" },
      "emphasis": { "$value": "1.4s"  }
    },
    "easing": {
      "spring":   { "$value": "cubic-bezier(0.22, 1, 0.36, 1)" },
      "ease-out": { "$value": "cubic-bezier(0.16, 1, 0.30, 1)" },
      "ease-inout":{ "$value": "cubic-bezier(0.45, 0, 0.55, 1)" }
    },
    "keyframes": {
      "logo-reveal":  "toby-logo-reveal",
      "logo-breathe": "toby-logo-breathe",
      "spark-sweep":  "toby-spark-sweep",
      "shimmer":      "shimmer",
      "fade-in":      "fadeIn",
      "slide-up":     "slideUp"
    }
  },
  "borderRadius": {
    "sm":   { "$value": "0.5rem",  "$use": "badges, chips" },
    "md":   { "$value": "0.75rem", "$use": "inputs, small cards" },
    "lg":   { "$value": "0.9rem",  "$use": "main cards, panels" },
    "xl":   { "$value": "1.25rem", "$use": "large cards, modals" },
    "full": { "$value": "9999px",  "$use": "pills, rounded buttons" }
  }
}
